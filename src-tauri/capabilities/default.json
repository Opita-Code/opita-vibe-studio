{
  "identifier": "default",
  "description": "Default capability set for Vibe Studio",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-stat",
    "fs:allow-read-dir",
    "shell:default",
    "shell:allow-execute",
    "shell:allow-open",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
