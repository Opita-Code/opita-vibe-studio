# Opita Vibe Studio — Environment Configuration
# Copy this file to .env and fill in your values.

# AWS Backend Configuration (SST)
VITE_API_URL=https://api.opitacode.com
VITE_AWS_API_URL=https://<your-lambda-id>.lambda-url.<region>.on.aws/

# Wompi Configuration (Monetization)
VITE_WOMPI_PUBLIC_KEY=pub_test_your_wompi_key_here

# DeepSeek Configuration
VITE_DEEPSEEK_KEY=sk-your_deepseek_key_here
