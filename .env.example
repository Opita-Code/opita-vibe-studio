# Opita Vibe Studio — Environment Configuration
# Copy this file to .env and fill in your values.

# ─── Required ────────────────────────────────────────────
JWT_SECRET=                     # Secret for signing JWT tokens (generate a random 48+ char string)

# ─── AWS Backend (SST) ──────────────────────────────────
VITE_API_URL=https://api.opitacode.com
VITE_AWS_API_URL=               # Lambda Function URL (e.g. https://<id>.lambda-url.<region>.on.aws/)
SES_FROM_EMAIL=auth@opitacode.com
FRONTEND_URL=http://localhost:5173

# ─── AI Providers ────────────────────────────────────────
DEEP_SEEK_KEY=                  # DeepSeek API key
GEMINI_API_KEY=                 # Google Gemini API key
OPENAI_API_KEY=                 # OpenAI API key (optional)
OPENROUTER_API_KEY=             # OpenRouter API key (optional)

# ─── Billing (Wompi) ────────────────────────────────────
WOMPI_PUBLIC_KEY=
WOMPI_WEBHOOK_SECRET=
WOMPI_INTEGRITY_SECRET=
VITE_WOMPI_PUBLIC_KEY=          # Frontend public key for checkout
